{
  "name": "math-rush-kids",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "rm -rf .tmp-test && tsc -p tsconfig.test.json && node --experimental-specifier-resolution=node .tmp-test/game-core/src/gameplay/mathRush.test.js && node .tmp-test/platform-wechat/src/canvasShell.test.js",
    "build:wechat": "tsc -b && vite build --config platform-wechat/vite.config.ts && node scripts/prepare-wechat.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
